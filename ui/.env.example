# Copy this file to .env and fill in your values.

# ThirdWeb Client ID — get one for free at https://thirdweb.com/dashboard
VITE_THIRDWEB_CLIENT_ID=YOUR_THIRDWEB_CLIENT_ID

# Optional: override the deployed contract address at runtime
# (the deploy script writes ui/src/contract-address.json automatically)
# VITE_CONTRACT_ADDRESS=0xYourContractAddress

# Optional: off-chain dataset API endpoint for objective iv analytics
VITE_DATASET_API_URL=http://127.0.0.1:3030
